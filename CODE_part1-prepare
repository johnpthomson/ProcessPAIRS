# --- Step 1: Classify each patient-gene-sample_type event ---
library(dplyr)
library(tidyr)
library(stringr)
library(ggplot2)

total_patients <- 38  # Known total patients

# Step 1: Get events per patient/sample_type/gene
brca_events <- merged %>%
  filter(gene %in% c("BRCA1", "BRCA2")) %>%
  mutate(
    patient = str_remove(Tumor_Sample_Barcode, "_(gDNA|Pre|Post)$"),
    sample_type = str_extract(Tumor_Sample_Barcode, "(gDNA|Pre|Post)"),
    has_snv = !is.na(snv.id.1) | !is.na(snv.id.2),
    has_cn = cn != 2,
    event_group = case_when(
      has_snv & has_cn ~ "SNV + CN",
      has_snv & !has_cn ~ "SNV only",
      !has_snv & has_cn ~ "CN only",
      TRUE ~ NA_character_
    )
  ) %>%
  filter(!is.na(event_group)) %>%
  select(patient, sample_type, gene, event_group) %>%
  distinct()

# Step 2: Identify patients with any BRCA event by gene
brca1_patients <- brca_events %>%
  filter(gene == "BRCA1") %>%
  distinct(patient, sample_type, event_group)

brca2_patients <- brca_events %>%
  filter(gene == "BRCA2") %>%
  distinct(patient, sample_type, event_group)

# Step 3: Full list of patient/sample_type from merged data
all_patients_samples <- merged %>%
  mutate(patient = str_remove(Tumor_Sample_Barcode, "_(gDNA|Pre|Post)$"),
         sample_type = str_extract(Tumor_Sample_Barcode, "(gDNA|Pre|Post)")) %>%
  distinct(patient, sample_type)

# Step 4: Join BRCA1 and BRCA2 events per patient/sample_type
brca_combined <- all_patients_samples %>%
  left_join(brca1_patients %>% rename(event_group_brca1 = event_group),
            by = c("patient", "sample_type")) %>%
  left_join(brca2_patients %>% rename(event_group_brca2 = event_group),
            by = c("patient", "sample_type"))

# Step 5: Assign gene_group and combined event_group per patient/sample_type
brca_combined <- brca_combined %>%
  mutate(
    gene_group = case_when(
      !is.na(event_group_brca1) & !is.na(event_group_brca2) ~ "BRCA1 + BRCA2",
      !is.na(event_group_brca1) & is.na(event_group_brca2) ~ "BRCA1 only",
      is.na(event_group_brca1) & !is.na(event_group_brca2) ~ "BRCA2 only",
      TRUE ~ "No BRCA event"
    ),
    event_group = case_when(
      gene_group == "No BRCA event" ~ "No event",
      gene_group == "BRCA1 + BRCA2" ~ {
        case_when(
          event_group_brca1 == "SNV + CN" | event_group_brca2 == "SNV + CN" ~ "SNV + CN",
          (event_group_brca1 == "SNV only" & event_group_brca2 == "CN only") |
          (event_group_brca1 == "CN only" & event_group_brca2 == "SNV only") ~ "SNV + CN",
          event_group_brca1 == "SNV only" & event_group_brca2 == "SNV only" ~ "SNV only",
          event_group_brca1 == "CN only" & event_group_brca2 == "CN only" ~ "CN only",
          TRUE ~ "SNV + CN"
        )
      },
      gene_group == "BRCA1 only" ~ event_group_brca1,
      gene_group == "BRCA2 only" ~ event_group_brca2,
      TRUE ~ "No event"
    )
  ) %>%
  select(patient, sample_type, gene_group, event_group)

# Step 6: Count number of patients per group/sample_type/event
full_event_counts <- brca_combined %>%
  group_by(gene_group, sample_type, event_group) %>%
  summarise(num_patients = n(), .groups = "drop")

# Step 7: Manual adjustment for gDNA No event count to ensure total = 38
gDNA_counts <- full_event_counts %>%
  filter(sample_type == "gDNA" & gene_group != "No BRCA event")

sum_gDNA_events <- sum(gDNA_counts$num_patients)

# Calculate corrected No BRCA event for gDNA
corrected_no_event_gDNA <- total_patients - sum_gDNA_events

# Update the No BRCA event count for gDNA
full_event_counts <- full_event_counts %>%
  mutate(num_patients = ifelse(
    gene_group == "No BRCA event" & sample_type == "gDNA",
    corrected_no_event_gDNA,
    num_patients
  ))

# Step 8: Factor levels for plotting
full_event_counts$gene_group <- factor(
  full_event_counts$gene_group,
  levels = c("BRCA1 only", "BRCA2 only", "BRCA1 + BRCA2", "No BRCA event")
)
full_event_counts$sample_type <- factor(full_event_counts$sample_type, levels = c("gDNA", "Pre", "Post"))
full_event_counts$event_group <- factor(full_event_counts$event_group,
                                        levels = c("SNV only", "CN only", "SNV + CN", "No event"))

# Step 9: Colors (grey for no event)
final_colors <- c(
  "SNV only" = "#1f77b4",
  "CN only" = "#ff7f0e",
  "SNV + CN" = "#2ca02c",
  "No event" = "grey80"
)

# Step 10: Plot
ggplot(full_event_counts, aes(x = sample_type, y = num_patients, fill = event_group)) +
  geom_bar(stat = "identity", position = "stack") +
  facet_wrap(~gene_group, nrow = 1) +
  geom_text(aes(label = ifelse(num_patients > 0, num_patients, "")),
            position = position_stack(vjust = 0.5), size = 4) +
  scale_fill_manual(values = final_colors) +
  labs(
    title = "BRCA1/2 Events by Sample Type with No Event Counts (Adjusted gDNA)",
    x = "Sample Type",
    y = "Number of Patients",
    fill = "Event Type"
  ) +
  theme_minimal(base_size = 14)

# Optional: print to check
print(full_event_counts)




