# --- Main driver & confidence (tier-aware, order-respecting) ---
# --- MAIN DRIVER SELECTION FUNCTION (v5) ---
get_tier_driver_v5 <- function(df_row, resistance_rows) {
  patient_id <- df_row$patient
  tier <- df_row$resistance_tier
  
  # Get all events for this patient
  events <- resistance_rows %>% filter(patient == patient_id)
  
  # Helper: pick first gene according to ordered list, appending CN type if present
  pick_by_order <- function(ev, ordered_genes) {
    if (nrow(ev) == 0) return(".")
    ev <- ev %>%
      mutate(rank = match(gene, ordered_genes)) %>%
      arrange(rank)
    
    # --- Append CN change if available ---
    gene_name <- ev$gene[1]
    cn_type <- if(!is.na(ev$cn_desc[1])) paste0("(", ev$cn_desc[1], ")") else ""
    snv_type <- if(!is.na(ev$snv_desc[1])) paste0("(", ev$snv_desc[1], ")") else ""
    
    paste0(gene_name, ": ", cn_type, if(cn_type!="" & snv_type!="") " + " else "", snv_type)
  }
  
  # -----------------------------
  # Tier 1: BRCA SNV reversion
  # -----------------------------
  if (tier == "1.BRCA_reversion") {
    ev <- events %>% filter(brca_snv)
    if (nrow(ev) > 0) return(pick_by_order(ev, c("BRCA1","BRCA2")))
  }
  
  # -----------------------------
  # Tier 2: Post-SNV drivers (2.1–2.3)
  # -----------------------------
  if (grepl("^2\\.", tier)) {
    ev <- events %>% filter(!is.na(snv_desc))
    if (nrow(ev) > 0) {
      for (gene_list in list(core, modifiers, exploratory)) {
        ev_sub <- ev %>% filter(gene %in% gene_list)
        if (nrow(ev_sub) > 0) return(pick_by_order(ev_sub, gene_list))
      }
    }
  }
  
# -----------------------------
# Tier 3: CN events (3.1–3.3), BRCA excluded
# -----------------------------
if (grepl("^3\\.", tier)) {
  
  ev <- cn_event_flag %>%
    filter(patient == patient_id & cn_event == TRUE)
  
  # Restrict to tier-specific gene list
  if (tier == "3.1.Core_CN_event") {
    ev <- ev %>% filter(gene %in% core & !gene %in% c("BRCA1","BRCA2"))
  }
  if (tier == "3.2.Modifier_CN_event") {
    ev <- ev %>% filter(gene %in% modifiers)
  }
  if (tier == "3.3.Exploratory_CN_event") {
    ev <- ev %>% filter(gene %in% exploratory)
  }
  
  if (nrow(ev) > 0) {
    
    # Determine CN direction biologically
    ev <- ev %>%
      mutate(
        cn_change = case_when(
          cn_num_Pre < 2 & cn_num_Post >= 2 ~ "CN_restored",
          cn_num_Post > cn_num_Pre & cn_num_Post > 2 ~ "CN_gain",
          cn_num_Post < cn_num_Pre & cn_num_Post < 2 ~ "CN_loss",
          TRUE ~ "CN_change"
        )
      )
    
    gene_name <- ev$gene[1]
    cn_label  <- ev$cn_change[1]
    
    return(paste0(gene_name, ": ", cn_label))
  }
}

  
  # -----------------------------
  # Tier 4: BRCA CN restore (4.1 / 4.2)
  # -----------------------------
  if (grepl("^4\\.", tier)) {
    ev <- events %>% filter(brca_cn)
    if (nrow(ev) > 0) {
      gene_name <- ev$gene[1]
      cn_type <- ifelse(!is.na(ev$cn_desc[1]), paste0("(", ev$cn_desc[1], ")"), "")
      snv_type <- ifelse(!is.na(ev$snv_desc[1]), paste0("(", ev$snv_desc[1], ")"), "")
      paste0(gene_name, ": ", cn_type, if(cn_type!="" & snv_type!="") " + " else "", snv_type)
    }
  }
  
  # -----------------------------
  # Tier 5: No driver
  # -----------------------------
  return(".")
}




