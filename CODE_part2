# --- Helper functions ---
to_num_cn <- function(x) {
  sapply(x, function(v) {
    if (is.na(v) || v %in% c(".", "")) return(2L)
    nv <- suppressWarnings(as.numeric(v))
    if (is.na(nv)) return(2L)
    as.integer(round(nv))
  }, USE.NAMES = FALSE)
}

format_snv_text <- function(snv_count) {
  if (snv_count == 0) return(NULL)
  if (snv_count == 1) return("SNV")
  paste0("SNV x", snv_count)
}

make_event_status <- function(snv_count, cn_num) {
  snv_count <- ifelse(is.na(snv_count), 0L, as.integer(snv_count))
  cn_num <- ifelse(is.na(cn_num), 2L, as.integer(cn_num))
  mapply(function(snv, cn) {
    if (snv == 0L && cn == 2L) return(".")
    parts <- c()
    snv_text <- format_snv_text(snv)
    if (!is.null(snv_text)) parts <- c(parts, snv_text)
    if (cn != 2L) parts <- c(parts, paste0("CN=", cn))
    paste(parts, collapse = " + ")
  }, snv_count, cn_num, USE.NAMES = FALSE)
}

# --- CN and SNV interpretation ---
interpret_cn_event <- function(pre, post, gene, gene_type) {
  pre <- ifelse(is.na(pre), 2L, as.integer(pre))
  post <- ifelse(is.na(post), 2L, as.integer(post))
  is_tsg <- !is.na(gene_type) && grepl("TSG", gene_type, ignore.case = TRUE)
  is_onco <- !is.na(gene_type) && grepl("Oncogene", gene_type, ignore.case = TRUE)

  if (gene %in% c("BRCA1","BRCA2") && is_tsg && pre < 2 && post >= 2)
    return("BRCA_CN_restored")
  if (is_tsg && !gene %in% c("BRCA1","BRCA2")) {
    if (post < pre) return("TSG_CN_loss")
    if (post > pre && pre < 2) return("TSG_CN_restoration")
  }
  if (is_onco) {
    if (post > pre) return("ONCO_CN_gain")
    if (post < pre && pre > 2) return("ONCO_CN_restoration")
  }
  return(NA_character_)
}

interpret_snv_event <- function(pre_count, post_count, gene = NULL, pre_vaf = NA, post_vaf = NA) {
  pre  <- ifelse(is.na(pre_count), 0L, as.integer(pre_count))
  post <- ifelse(is.na(post_count), 0L, as.integer(post_count))
  
  # --- New SNV in Post ---
  if (pre == 0L && post > 0L) {
    if (!is.null(gene) && gene %in% c("BRCA1","BRCA2"))
      return("BRCA_SNV_acquired")
    return("SNV_acquired")
  }
  
  # --- Increased SNV count (new SNVs on top of existing) ---
  if (post > pre) {
    if (!is.null(gene) && gene %in% c("BRCA1","BRCA2"))
      return("BRCA_SNV_acquired")
    return("SNV_acquired")
  }
  
  # --- VAF increase >25% absolute ---
  if (!is.na(pre_vaf) && !is.na(post_vaf)) {
    if ((post_vaf - pre_vaf) > 0.25) {
      if (!is.null(gene) && gene %in% c("BRCA1","BRCA2"))
        return("BRCA_SNV_VAF_increase")
      return("SNV_VAF_increase")
    }
  }
  
  return(NA_character_)
}

