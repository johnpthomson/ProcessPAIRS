# --- Helper functions ---
to_num_cn <- function(x) {
  sapply(x, function(v) {
    if (is.na(v) || v %in% c(".", "")) return(2L)
    nv <- suppressWarnings(as.numeric(v))
    if (is.na(nv)) return(2L)
    as.integer(round(nv))
  }, USE.NAMES = FALSE)
}

format_snv_text <- function(snv_count) {
  if (snv_count == 0) return(NULL)
  if (snv_count == 1) return("SNV")
  paste0("SNV x", snv_count)
}

make_event_status <- function(snv_count, cn_num) {
  snv_count <- ifelse(is.na(snv_count), 0L, as.integer(snv_count))
  cn_num <- ifelse(is.na(cn_num), 2L, as.integer(cn_num))
  mapply(function(snv, cn) {
    if (snv == 0L && cn == 2L) return(".")
    parts <- c()
    snv_text <- format_snv_text(snv)
    if (!is.null(snv_text)) parts <- c(parts, snv_text)
    if (cn != 2L) parts <- c(parts, paste0("CN=", cn))
    paste(parts, collapse = " + ")
  }, snv_count, cn_num, USE.NAMES = FALSE)
}

# ======================================================
# CN resistance interpretation using annotation rules
# ======================================================

interpret_cn_direction <- function(pre, post, direction_rule) {

  # Safety coercion
  pre  <- ifelse(is.na(pre), 2L, as.integer(pre))
  post <- ifelse(is.na(post), 2L, as.integer(post))

  # Ignore unclear genes
  if (is.na(direction_rule) || direction_rule == "UNCLEAR") {
    return(NA_character_)
  }

  # --------------------------------------------------
  # LOSS-driven resistance genes
  # Example:
  # TP53BP1
  # REV7
  # PTIP
  # --------------------------------------------------

  if (direction_rule == "LOSS") {

    # CN decreases from Pre -> Post
    if (post < pre) {
      return("CN_LOSS")
    }
  }

  # --------------------------------------------------
  # GAIN-driven resistance genes
  # Example:
  # ABCB1
  # RAD51
  # BRCA restoration
  # --------------------------------------------------

  if (direction_rule == "GAIN") {

    # CN increases from Pre -> Post
    if (post > pre) {
      return("CN_GAIN")
    }
  }

  return(NA_character_)
}


# ======================================================
# SNV resistance interpretation using annotation rules
# ======================================================

interpret_snv_axis <- function(
  pre_count,
  post_count,
  snv_axis,
  pre_vaf = NA,
  post_vaf = NA
) {

  pre  <- ifelse(is.na(pre_count), 0L, as.integer(pre_count))
  post <- ifelse(is.na(post_count), 0L, as.integer(post_count))

  # Ignore unclear genes
  if (is.na(snv_axis) || snv_axis == "UNCLEAR") {
    return(NA_character_)
  }

  # --------------------------------------------------
  # POST-ACQUIRED PATHOGENIC
  # --------------------------------------------------

  if (snv_axis == "POST_ACQUIRED_PATHOGENIC") {

    # New post mutation
    if (pre == 0L && post > 0L) {
      return("POST_ACQUIRED_PATHOGENIC")
    }

    # Expansion in mutation burden
    if (post > pre) {
      return("POST_ACQUIRED_PATHOGENIC")
    }

    # Optional VAF expansion support
    if (!is.na(pre_vaf) && !is.na(post_vaf)) {

      if ((post_vaf - pre_vaf) > 0.25) {
        return("POST_ACQUIRED_PATHOGENIC")
      }
    }
  }

  # --------------------------------------------------
  # SECONDARY REVERSION
  # --------------------------------------------------

  if (snv_axis == "SECONDARY_REVERSION") {

    # Newly appearing reversion
    if (pre == 0L && post > 0L) {
      return("SECONDARY_REVERSION")
    }

    # Increased post burden
    if (post > pre) {
      return("SECONDARY_REVERSION")
    }
  }

  return(NA_character_)
}
  

