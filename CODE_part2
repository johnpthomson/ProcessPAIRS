# --- SNV evolution ---
classify_snv <- function(pre, post) {
  if (is.na(pre) & !is.na(post)) return("Acquired")
  if (!is.na(pre) & is.na(post)) return("Lost")
  if (!is.na(pre) & !is.na(post)) {
    if ((post - pre) >= 0.25) return("VAF_up")
    if ((pre - post) >= 0.25) return("VAF_down")
    return("Stable")
  }
  return(NA)
}

