  group_by(patient) %>%
  summarise(
    Acquired = sum(evolution == "Acquired", na.rm = TRUE),
    Lost     = sum(evolution == "Lost", na.rm = TRUE),
    Stable   = sum(evolution == "Stable", na.rm = TRUE),
    VAF_up   = sum(evolution == "VAF_up", na.rm = TRUE),
    VAF_down = sum(evolution == "VAF_down", na.rm = TRUE),
    .groups = "drop"
  ) %>%
  rowwise() %>%
  mutate(Tumor_Evolution = paste(c(
    if (Acquired>0) paste0("Acquired: ",Acquired) else NULL,
    if (Lost>0) paste0("Lost: ",Lost) else NULL,
    if (Stable>0) paste0("Stable: ",Stable) else NULL,
    if (VAF_up>0) paste0("VAF_up: ",VAF_up) else NULL,
    if (VAF_down>0) paste0("VAF_down: ",VAF_down) else NULL
  ), collapse="; ")) %>% ungroup() %>%
  select(patient, Tumor_Evolution)

hrd_status_wide <- hrd_status_wide %>% left_join(evolution_summary, by = "patient")

hrd_status_wide <- hrd_status_wide %>%
  mutate(
    genomic_directionality = case_when(
      str_detect(Tumor_Evolution, "Acquired") ~ "Adaptive",
      resistance_tier == "1.BRCA_reversion" ~ "Adaptive",
      resistance_tier %in% c("2.1.Core_post_SNV","2.2.Modifier_post_SNV","2.3.Exploratory_post_SNV") ~ "Mixed",
      TRUE ~ "No evidence of adaptation"
    )
  )



# --- SNV gene lists for evolution ---
snv_gene_lists <- snv_wide %>%
  group_by(patient) %>%
  summarise(
    Acquired = if(any(evolution == "Acquired")) paste("Acquired:", paste(gene[evolution=="Acquired"], collapse = ",")) else NA_character_,
    Lost     = if(any(evolution == "Lost"))     paste("Lost:", paste(gene[evolution=="Lost"], collapse = ",")) else NA_character_,
    VAF_up   = if(any(evolution == "VAF_up"))   paste("VAF_up:", paste(gene[evolution=="VAF_up"], collapse = ",")) else NA_character_,
    VAF_down = if(any(evolution == "VAF_down")) paste("VAF_down:", paste(gene[evolution=="VAF_down"], collapse = ",")) else NA_character_,
    .groups = "drop"
  ) %>%
  rowwise() %>%
  mutate(SNV_Gene_Evolution = paste(na.omit(c(Acquired, Lost, VAF_up, VAF_down)), collapse = "; ")) %>%
  ungroup() %>%
  select(patient, SNV_Gene_Evolution)

hrd_status_wide <- hrd_status_wide %>%
  left_join(snv_gene_lists, by = "patient") %>%
  mutate(SNV_Gene_Evolution = ifelse(is.na(SNV_Gene_Evolution), ".", SNV_Gene_Evolution))

# --- SBS3 integration ---
sig03_sh <- read.delim("sig03_sh.txt", stringsAsFactors = FALSE)
sig03_long <- sig03_sh %>%
  mutate(patient = str_remove(ID, "_(gDNA|Pre|Post)$"),
         sample_type = str_extract(ID, "(gDNA|Pre|Post)")) %>%
  filter(sample_type %in% c("Pre","Post")) %>%
  mutate(sig3_class = case_when(SBS3 >= 0.2 ~ "HRD",
                                SBS3 >= 0.1 & SBS3 < 0.2 ~ "Low_conf_HRD",
                                SBS3 < 0.1 ~ "Non_HRD", TRUE ~ "Unknown"))

sig03_wide <- sig03_long %>%
  select(patient, sample_type, sig3_class) %>%
  pivot_wider(names_from = sample_type, values_from = sig3_class, names_prefix = "sig3_")

hrd_status_wide <- hrd_status_wide %>% left_join(sig03_wide, by = "patient")

# --- Prepare wide HRD events ---
hrd_wide_events <- hrd_events %>%
  mutate(event_status = make_event_status(snv_count, cn_num)) %>%
  select(patient, gene, sample_type, event_status) %>%
  pivot_wider(names_from = c(gene, sample_type), values_from = event_status, names_sep = "_")

brca_cols <- c("BRCA1_gDNA","BRCA1_Pre","BRCA1_Post",
               "BRCA2_gDNA","BRCA2_Pre","BRCA2_Post")
               
               
               
# ======================================================
# FINAL BIOLOGICAL RESISTANCE CLASSIFIER (V8)
# ======================================================

# --- Define biologically relevant bypass genes/pathways ---
fork_protection_genes <- c(
  "TP53BP1","RIF1","REV7","MAD2L2","SHLD1","SHLD2","SHLD3",
  "RAD51C","RAD51D","RAD51B","PALB2",
  "FANCA","FANCD2","FANCI",
  "ATR","ATM","CHEK1","CHEK2",
  "POLQ","PARP1","PARG","SLFN11"
)

# --- Summarise adaptive complexity metrics ---
complexity_metrics <- resistance_gene_rows %>%
  group_by(patient) %>%
  summarise(
    total_driver_events = n(),
    unique_driver_genes = n_distinct(gene),
    mixed_event_types = n_distinct(c(
      ifelse(!is.na(snv_desc), "SNV", NA),
      ifelse(!is.na(cn_desc), "CN", NA)
    ), na.rm = TRUE),
    
    bypass_gene_event = any(gene %in% fork_protection_genes),
    
    .groups = "drop"
  )

# --- Join complexity metrics ---
hrd_status_wide <- hrd_status_wide %>%
  left_join(complexity_metrics, by = "patient") %>%
  mutate(
    total_driver_events = ifelse(is.na(total_driver_events), 0, total_driver_events),
    unique_driver_genes = ifelse(is.na(unique_driver_genes), 0, unique_driver_genes),
    mixed_event_types   = ifelse(is.na(mixed_event_types), 0, mixed_event_types),
    bypass_gene_event   = ifelse(is.na(bypass_gene_event), FALSE, bypass_gene_event)
  )

# ======================================================
# FINAL CLASSIFIER ASSIGNMENT
# ======================================================

hrd_status_wide <- hrd_status_wide %>%
  mutate(

    final_classifier = case_when(

      # --------------------------------------------------
      # 1. BRCA-associated adaptive restoration
      # TRUE BRCA SNV reversions only
      # --------------------------------------------------
      resistance_tier %in% c(
        "1.BRCA_reversion"
      ) ~ "1.BRCA_associated_adaptive_restoration",
      
      # --------------------------------------------------
      # OVERRIDE:
      # BRCA restoration + bypass event
      # = complex adaptive state
      # --------------------------------------------------
      has_brca_restoration &
      (
        bypass_gene_event |
        resistance_tier %in% c(
          "2.1.Core_post_SNV",
          "2.2.Modifier_post_SNV",
          "2.3.Exploratory_post_SNV",
          "3.1.Core_CN_event",
          "3.2.Modifier_CN_event",
          "3.3.Exploratory_CN_event"
        )
      ) ~ "3.Complex_adaptive_genomic_state",

# --------------------------------------------------
# 2. HR bypass / fork protection resistance (split)
# --------------------------------------------------
(
  bypass_gene_event |
  resistance_tier %in% c(
    "2.1.Core_post_SNV",
    "2.2.Modifier_post_SNV",
    "2.3.Exploratory_post_SNV",
    "3.1.Core_CN_event",
    "3.2.Modifier_CN_event",
    "3.3.Exploratory_CN_event"
  )
) ~ case_when(
  
  !is.na(pathways_involved) & str_detect(pathways_involved, "\\bHR\\b") ~
    "2a.HR_bypass",
  
  TRUE ~
    "2b.Fork_protection"
),
      # --------------------------------------------------
      # 3. Complex adaptive genomic states
      # Includes BRCA CN restoration / complex states
      # --------------------------------------------------
      resistance_tier %in% c(
        "4.1.BRCA_CN_restore_no_shared_SNV",
        "4.2.BRCA_complex"
      ) |

      (
        total_driver_events >= 3 &
        unique_driver_genes >= 3
      ) |

      (
        genomic_directionality == "Adaptive" &
        mixed_event_types >= 2
      ) ~ "3.Complex_adaptive_genomic_state",

      # --------------------------------------------------
      # 4. No clear mechanism
      # --------------------------------------------------
      resistance_tier == "5.No_driver" ~
        "4.No_clear_genomic_resistance",

      TRUE ~ "4.No_clear_genomic_resistance"
    )
  )

# ======================================================
# FINAL POST-HOC CLASSIFIER SANITY OVERRIDE
# ======================================================

fork_protection_genes <- c(
  "TP53BP1","RIF1","REV7","MAD2L2","SHLD1","SHLD2","SHLD3"
)

hr_bypass_genes <- c(
  "ATR","ATM","CHEK1","CHEK2","RAD51B","RAD51C","RAD51D","PALB2",
  "BRCA1","BRCA2","BARD1","BRIP1"
)

hrd_status_wide <- hrd_status_wide %>%
  mutate(

    final_classifier = case_when(

      # --------------------------------------------------
      # PROTECT TIER 1 (DO NOT TOUCH)
      # --------------------------------------------------
      resistance_tier == "1.BRCA_reversion" ~
        final_classifier,

      # --------------------------------------------------
      # Fork protection (2b)
      # --------------------------------------------------
      str_detect(main_driver, paste0("\\b(", paste(fork_protection_genes, collapse="|"), ")\\b")) ~
        "2b.Fork_protection",

      # --------------------------------------------------
      # HR bypass (2a)
      # IMPORTANT: explicitly exclude BRCA genes here
      # --------------------------------------------------
      str_detect(main_driver, paste0("\\b(", paste(setdiff(hr_bypass_genes, c("BRCA1","BRCA2")), collapse="|"), ")\\b")) ~
        "2a.HR_bypass",

      TRUE ~ final_classifier
    )
  )

# ======================================================
# OPTIONAL: HUMAN-READABLE DESCRIPTION COLUMN
# ======================================================

hrd_status_wide <- hrd_status_wide %>%
  mutate(
    final_classifier_description = case_when(

      final_classifier == "1.BRCA_associated_adaptive_restoration" ~
        "Evidence of BRCA restoration or BRCA-associated adaptive resistance",

      final_classifier == "2a.HR_bypass" ~
        "Evidence of HR pathway bypass or replication stress–driven adaptation",

      final_classifier == "2b.Fork_protection" ~
        "Evidence of fork protection / NHEJ-Shieldin axis activation",

      final_classifier == "3.Complex_adaptive_genomic_state" ~
        "Mixed adaptive genomic evolution without single dominant driver",

      final_classifier == "4.No_clear_genomic_resistance" ~
        "No convincing genomic resistance mechanism identified",

      TRUE ~ "."
    )
  )
# --- Final output ---
final_out <- hrd_status_wide %>%
  left_join(hrd_wide_events %>% select(patient, any_of(brca_cols)), by="patient") %>%
  mutate(BRCA_context = BRCA_context) %>%   # exposes the BRCA_context column in final_out
  select(
    patient,
    final_classifier,
    final_classifier_description,
    BRCA_context,
    any_of(brca_cols),
    resistance_report,
    resistance_tier,
    resistance_mechanism,
    main_driver,
    driver_confidence,
    biallelic_HR_event,
    genomic_directionality,
    pathways_involved,
    Tumor_Evolution,
    SNV_Gene_Evolution,
    any_of(c("sig3_Pre","sig3_Post"))
  ) %>%   
  group_by(patient) %>%
  slice(1) %>%
  ungroup()

write.table(final_out,
            "hrd_status_summary_with_resistance_tiers-8-2.txt",
            sep = "\t", quote = FALSE, row.names = FALSE)
