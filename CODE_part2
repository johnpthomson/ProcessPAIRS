# ======================================================

driver_events <- resistance_gene_rows %>%

  mutate(

    # -----------------------------
    # Event type
    # -----------------------------
    event_type = case_when(

      !is.na(snv_desc) & !is.na(cn_desc) ~ "SNV+CN",

      !is.na(snv_desc) ~ "SNV",

      !is.na(cn_desc) ~ "CN",

      TRUE ~ "OTHER"
    ),

    # -----------------------------
    # BRCA shared mutation logic
    # TRUE reversion requires:
    # Pre-existing mutation PLUS
    # additional post event
    # -----------------------------
    shared_pre_post_snv =
      snv_count_Pre > 0 &
      snv_count_Post > snv_count_Pre,

    # -----------------------------
    # True BRCA adaptive restoration
    # -----------------------------
    true_brca_reversion = case_when(

      gene %in% c("BRCA1","BRCA2") &
      snv_axis == "SECONDARY_REVERSION" &
      shared_pre_post_snv ~ TRUE,

      TRUE ~ FALSE
    ),

    # -----------------------------
    # Adaptive evidence score
    # Used later for ranking
    # -----------------------------
    driver_score = case_when(

      true_brca_reversion ~ 100,

      classifier_group == "1.BRCA_restoration" &
      event_type == "SNV" ~ 90,

      classifier_group == "1.BRCA_restoration" &
      event_type == "SNV+CN" ~ 85,

      classifier_group == "2a.HR_bypass" &
      event_type == "SNV" ~ 70,

