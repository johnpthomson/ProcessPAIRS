# ======================================================
# SNV EVOLUTION ADD-ON (SNV-ID BASED: Acquired / Lost / Shared)
# ======================================================

library(dplyr)
library(tidyr)
library(stringr)

# ----------------------------
# 1. Build MASTER SNV catalogue from snv_sh
# ----------------------------

snv_catalog <- snv_sh %>%
  
  mutate(
    patient = str_remove(Tumor_Sample_Barcode, "_(gDNA|Pre|Post)$"),
    sample_type = str_extract(Tumor_Sample_Barcode, "(gDNA|Pre|Post)")
  ) %>%
  
  filter(!is.na(snv_id)) %>%
  
  distinct(patient, snv_id, sample_type)

# ----------------------------
# 2. Pivot to PRE / POST presence matrix
# ----------------------------

snv_matrix <- snv_catalog %>%
  
  mutate(present = 1L) %>%
  
  pivot_wider(
    names_from = sample_type,
    values_from = present,
    values_fill = list(present = 0)
  ) %>%
  
  mutate(
    Pre  = ifelse(is.na(Pre), 0L, Pre),
    Post = ifelse(is.na(Post), 0L, Post)
  )

# ----------------------------
# 3. Classify SNV state per SNV-ID
# ----------------------------

snv_states <- snv_matrix %>%
  
  mutate(
    
    snv_state = case_when(
      Pre == 0 & Post == 1 ~ "Acquired",
      Pre == 1 & Post == 0 ~ "Lost",
      Pre == 1 & Post == 1 ~ "Shared",
      TRUE ~ NA_character_
    )
  ) %>%
  
  filter(!is.na(snv_state))

# ----------------------------
# 4. Collapse to gene-level summaries (SNV-ID aware)
# ----------------------------

snv_gene_summary <- snv_sh %>%
  
  mutate(
    patient = str_remove(Tumor_Sample_Barcode, "_(gDNA|Pre|Post)$")
  ) %>%
  
  select(patient, gene, snv_id) %>%
  distinct() %>%
  
  inner_join(
    snv_states %>% select(patient, snv_id, snv_state),
    by = c("patient", "snv_id")
  ) %>%
  
  group_by(patient, snv_state) %>%
  
  summarise(
    gene_list = paste(sort(unique(gene)), collapse = ","),
    n_genes   = n_distinct(gene),
    n_snvs    = n_distinct(snv_id),
    .groups = "drop"
  )

# ----------------------------
# 5. Patient-level summary strings
# ----------------------------

snv_evolution_summary <- snv_gene_summary %>%
  
  group_by(patient) %>%
  
  summarise(
    
    Tumor_Evolution = paste(
      paste0(snv_state, ": ", n_snvs),
      collapse = "; "
    ),
    
    SNV_Gene_Evolution = paste(
      paste0(snv_state, ": ", gene_list),
      collapse = "; "
    ),
    
    .groups = "drop"
  )

# ----------------------------
# 6. Merge into main table (NO LOGIC CHANGE OUTSIDE THIS BLOCK)
# ----------------------------

hrd_status_wide <- hrd_status_wide %>%
  left_join(snv_evolution_summary, by = "patient")


# ======================================================
# FINAL OUTPUT TABLE
# ======================================================

final_out <- hrd_status_wide %>%

  select(

    patient,

    final_classifier,

    final_classifier_description,

    BRCA_context, 

    resistance_report,

    resistance_tier,

    resistance_mechanism,

    main_driver,

    main_driver_mechanism,

    main_driver_group,

    total_driver_events,

    genomic_directionality,
    
    BRCA_orf_restore,
    
    Tumor_Evolution,
    
    SNV_Gene_Evolution,

    pathways_involved,

    mechanisms_involved
  ) %>%

  distinct()
  
  
  
